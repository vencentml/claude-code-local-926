# Copy this file to .env.kimi and fill in your local values.
#
# Kimi / Moonshot credentials. These stay local and should not be committed.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Set this to a model your account can access. The proxy will use this model
# unless KIMI_STRICT_MODEL=true is set.
KIMI_MODEL=moonshot-v1-8k

# Local Anthropic-compatible proxy port.
ANTHROPIC_PROXY_PORT=3456

# Optional: if true, forward Claude Code's requested model name directly
# instead of forcing KIMI_MODEL.
KIMI_STRICT_MODEL=false

ANTHROPIC_CUSTOM_MODEL_OPTION=moonshot-v1-8k
ANTHROPIC_CUSTOM_MODEL_OPTION_NAME=Kimi
ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION=Custom Kimi model via local bridge
